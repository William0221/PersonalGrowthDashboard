 {q:"「停損」是在做什麼？",opts:["跌到設定價就認賠賣出","借錢買更多","當天買賣賺差價","把賺的錢再投入"],a:0,exp:"停損是事先講好的退場規則，跌到某價就賣，避免越賠越多。"},
 {q:"今天買台股，什麼時候會從帳戶扣款？",opts:["當天","第2個上班日(T+2)","隔週","下個月"],a:1,exp:"台股是T+2交割，第2個上班日才扣款，所以扣款日帳戶要有足夠的錢。"},
 {q:"ROE 高代表什麼？",opts:["股價很貴","用股東的錢賺錢效率高","欠債很多","波動很大"],a:1,exp:"ROE＝賺的錢÷股東投入的錢，越高代表錢被用得越會生錢，長期>15%通常是好公司。"},
 {q:"「自由現金流」像生活中的哪個概念？",opts:["月薪總額","付完房貸車貸後實際剩能花的錢","信用卡額度","存款利息"],a:1,exp:"自由現金流＝做完生意、付完該花的之後真正剩在口袋的現金，比帳面獲利更難灌水。"},
 {q:"散戶「追高殺低」是指？",opts:["買在貴、賣在便宜","低買高賣","長期持有","定期定額"],a:0,exp:"看到大漲才追買、看到大跌才嚇賣，剛好買貴賣便宜，是最常見的賠錢行為。"},
 {q:"放空的人因股價不跌反漲、被迫認賠買回而越推越高，叫？",opts:["軋空","洗盤","護盤","跳空"],a:0,exp:"軋空＝賭跌的人被漲勢逼著回補，回補的買盤又把價格推更高。"},
];

// ===== 學習模式 =====
const cats=["全部",...[...new Set(DATA.map(d=>d.cat))]];
let curCat="全部", kw="";
const tabsEl=document.getElementById('tabs');
const listEl=document.getElementById('list');
const countEl=document.getElementById('count');

cats.forEach((c,i)=>{
  const b=document.createElement('button');
  b.className='tab'+(i===0?' active':''); b.textContent=c;
  b.onclick=()=>{curCat=c;[...tabsEl.children].forEach(x=>x.classList.remove('active'));b.classList.add('active');render();};
  tabsEl.appendChild(b);
});

function render(){
  const q=kw.trim().toLowerCase();
  const items=DATA.filter(d=>(curCat==="全部"||d.cat===curCat)&&
    (!q||d.zh.toLowerCase().includes(q)||d.en.toLowerCase().includes(q)||d.def.toLowerCase().includes(q)));
  countEl.textContent=`共 ${items.length} 個名詞`;
  if(!items.length){listEl.innerHTML='<div class="empty">找不到符合的名詞 🔍<br>換個關鍵字試試</div>';return;}
  listEl.innerHTML=items.map(d=>`
    <div class="card">
      <h3>${d.zh}<span class="en">${d.en}</span><span class="cat-pill">${d.cat}</span></h3>
      <p>${d.def}</p>
      ${d.formula?`<div class="formula">📐 <b>算法</b>：${d.formula}</div>`:''}
      ${d.eg?`<div class="eg"><span class="ico">${d.icon||'🌱'}</span><span class="txt"><b>生活例子</b>：${d.eg}</span></div>`:''}
    </div>`).join('');
}
document.getElementById('search').addEventListener('input',e=>{kw=e.target.value;render();});
render();

// ===== 模式切換 =====
const learnView=document.getElementById('learnView');
const quizView=document.getElementById('quizView');
document.querySelectorAll('.mode-btn').forEach(b=>{
  b.onclick=()=>{
    document.querySelectorAll('.mode-btn').forEach(x=>x.classList.remove('active'));
    b.classList.add('active');
    if(b.dataset.mode==='quiz'){learnView.style.display='none';quizView.style.display='block';tabsEl.style.display='none';startQuiz();}
    else{quizView.style.display='none';learnView.style.display='block';tabsEl.style.display='flex';}
  };
});

// ===== 測驗模式 =====
let qi=0,score=0,order=[];
function startQuiz(){qi=0;score=0;order=[...QUIZ.keys()].sort(()=>Math.random()-0.5);showQ();}
function showQ(){
  if(qi>=order.length){
    quizView.innerHTML=`<div class="quizbox score">
      <div>測驗完成 🎉</div>
      <div class="big">${score} / ${order.length}</div>
      <div style="color:var(--sub);margin-top:6px">${score===order.length?'滿分！觀念非常扎實':score>=order.length*0.6?'不錯，再複習弱點即可':'建議回到學習模式再讀一遍'}</div>
      <button class="retry" onclick="startQuiz()">再測一次</button></div>`;
    return;
  }
  const item=QUIZ[order[qi]];
  const opts=item.opts.map((o,i)=>`<button class="opt" data-i="${i}">${o}</button>`).join('');
  quizView.innerHTML=`<div class="quizbox">
    <div class="q-prog">第 ${qi+1} / ${order.length} 題　·　目前得分 ${score}</div>
    <div class="q-text">${item.q}</div>
    <div id="opts">${opts}</div>
    <div class="q-exp" id="exp"></div>
    <button class="q-next" id="next">下一題 →</button></div>`;
  document.querySelectorAll('.opt').forEach(btn=>{
    btn.onclick=()=>{
      const pick=+btn.dataset.i;
      document.querySelectorAll('.opt').forEach(b=>{b.disabled=true;
        if(+b.dataset.i===item.a)b.classList.add('correct');});
      if(pick!==item.a)btn.classList.add('wrong'); else score++;
      const exp=document.getElementById('exp');exp.style.display='block';exp.innerHTML='✅ '+item.exp;
      document.getElementById('next').style.display='block';
    };
  });
  document.getElementById('next').onclick=()=>{qi++;showQ();};
}
</script>
